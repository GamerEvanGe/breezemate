# Copy this file to .env and fill in your real key.
# .env is gitignored.

# OpenAI key. Used by both the Realtime ASR backend (when selected)
# and the translation model when you pick the OpenAI provider preset.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME

# Optional: if you proxy OpenAI through a different host, override here.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional keys for other translation providers (only fill what you use):
# DEEPSEEK_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# ZHIPU_API_KEY=...
# SILICONFLOW_API_KEY=...
# DASHSCOPE_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# TOGETHER_API_KEY=...
